rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function existing() {
      return resource.data;
    }

    function incoming() {
      return request.resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'alwlydalsabqy360@gmail.com' || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true));
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'level', 'xp', 'coins', 'createdAt', 'updatedAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.level is number && data.level >= 1 &&
             data.xp is number && data.xp >= 0 &&
             data.coins is number && data.coins >= 0 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('isAdmin' in data) || data.isAdmin is bool) &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['title', 'category', 'url', 'active', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() <= 100 &&
             (!('image' in data) || (data.image is string && data.image.size() <= 500)) &&
             data.category is string && data.category.size() <= 50 &&
             (!('playersActive' in data) || (data.playersActive is number && data.playersActive >= 0)) &&
             (!('rating' in data) || data.rating is number) &&
             data.url is string && data.url.size() <= 500 &&
             (!('developer' in data) || (data.developer is string && data.developer.size() <= 100)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10 && (data.tags.size() == 0 || data.tags[0] is string))) &&
             data.active is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time && (isAdmin() || (!('isAdmin' in incoming()) || incoming().isAdmin == false));
      allow update: if (isSignedIn() && isValidId(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt) && (
        isAdmin() || (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'level', 'xp', 'coins']) && (!('isAdmin' in incoming().diff(existing()).affectedKeys())))
      );
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow get: if true;
      allow list: if true;

      allow create: if isAdmin() && isValidId(gameId) && isValidGame(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidId(gameId) && isValidGame(incoming()) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(gameId);
    }
  }
}
